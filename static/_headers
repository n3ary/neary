# Cloudflare Pages headers — mirrors what netlify.toml used to do.
# Pages reads this file at the root of the deploy directory.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# API proxy responses (GTFS-RT + Tranzy) — never cache. Live data.
/api/*
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate
  Pragma: no-cache
  Expires: 0

# SvelteKit version-poll manifest — MUST NOT be cached, otherwise the
# client can't detect new deploys. See svelte.config.js kit.version.
/_app/version.json
  Cache-Control: no-store, no-cache, must-revalidate

# HTML shell — always revalidate so a new deploy is picked up the next
# time the user lands on the page. Hashed JS/CSS inside /_app/immutable/*
# is cached aggressively by Cloudflare Pages defaults (immutable).
/*.html
  Cache-Control: no-cache, must-revalidate

/index.html
  Cache-Control: no-cache, must-revalidate

# Site-wide security headers.
/*
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  X-Content-Type-Options: nosniff

# App-bundled static assets that ship with hashed filenames.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
