# Cloudflare Pages headers — mirrors what netlify.toml used to do.
# Pages reads this file at the root of the deploy directory.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# API proxy responses (GTFS-RT) — never cache. Live data.
/api/*
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate
  Pragma: no-cache
  Expires: 0

# SvelteKit version-poll manifest — MUST NOT be cached, otherwise the
# client can't detect new deploys. See svelte.config.js kit.version.
/_app/version.json
  Cache-Control: no-store, no-cache, must-revalidate

# HTML shell — always revalidate so a new deploy is picked up the next
# time the user lands on the page. Hashed JS/CSS inside /_app/immutable/*
# is cached aggressively by Cloudflare Pages defaults (immutable).
/*.html
  Cache-Control: no-cache, must-revalidate

/index.html
  Cache-Control: no-cache, must-revalidate

# App-bundled static assets that ship with hashed filenames.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# ----------------------------------------------------------------------------
# Security headers — see n3ary/app#186.
#
# Scope note: Cloudflare Pages applies these to every host bound to the
# `neary` Pages project (currently app.n3ary.com). The same headers need to
# be added to the matching _headers files in n3ary/website (apex n3ary.com)
# and n3ary/branding (branding.n3ary.com). Zone-level HSTS in the Cloudflare
# dashboard → SSL/TLS → Edge Certificates covers all subdomains including
# R2 (gtfs.n3ary.com) and any future Workers / Tunnel origins in one toggle;
# prefer that for the actual fix and keep these per-project headers in sync
# as a defence-in-depth backstop.
# ----------------------------------------------------------------------------
/*
  # HSTS — force HTTPS for one year across all subdomains of n3ary.com.
  # Deliberately omits `preload`: preload is a one-way door (browsers cache
  # the directive for the max-age) and needs a separate submission to
  # hstspreload.org after a 1-year soak. Tracked in n3ary/app#186.
  Strict-Transport-Security: max-age=31536000; includeSubDomains

  # Clickjacking protection. Already on the n3ary.com apex; kept for parity
  # and to defend against regressions.
  X-Frame-Options: DENY

  # XSS filter hint for older browsers. Modern browsers ignore the header;
  # kept because Security Insights still checks for it and removing it
  # would re-surface a warning on the dashboard.
  X-XSS-Protection: 1; mode=block

  # Block MIME-type sniffing. Already on the apex; kept for parity.
  X-Content-Type-Options: nosniff

  # Referrer policy — same-origin / strict-origin (no path leak on
  # downgrade).
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions policy — opt out of FLoC/Topics + disable features the PWA
  # does not use. Geolocation stays open because src/lib/stores/
  # locationStore.svelte.ts uses navigator.geolocation.watchPosition; the
  # rest are explicitly denied.
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(self), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()

  # Baseline Content-Security-Policy. SvelteKit static + Svelte 5 need
  # 'unsafe-inline' for both scripts and styles (inline <div style="...">
  # in src/app.html, plus SvelteKit's hydration / module-preload bootstrap).
  # The policy still blocks object/frame injection, restricts origins for
  # images / data / workers, and forces HTTPS. Tighten with hashes once
  # SvelteKit's static CSP integration is in place. Tracked in n3ary/app#186.
  #
  # img-src origins:
  #   - 'self' data: blob:    inline data + worker-generated blobs (PWA icons
  #                            via Comlink, schedule export blobs, etc.)
  #   - https://branding.n3ary.com   favicons + social card (see src/app.html)
  #   - https://gtfs.n3ary.com       GTFS feed manifest + binary blobs
  #   - https://*.tile.openstreetmap.org   Leaflet map tiles + SW tile prefetch.
  #                            OSM rotates across a/b/c subdomains; the wildcard
  #                            covers all three. Attribution is set in code at
  #                            src/routes/map/route/[id]/[[selected]]/+page.svelte
  #                            ("OpenStreetMap contributors") so the
  #                            upstream tile usage policy is honoured.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://branding.n3ary.com https://gtfs.n3ary.com https://*.tile.openstreetmap.org; font-src 'self' data:; connect-src 'self' https://gtfs.n3ary.com https://gtfs-rt.n3ary.com https://*.tile.openstreetmap.org; worker-src 'self' blob:; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests
